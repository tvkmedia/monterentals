              "id": "e04d006",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"relative h-[460px] flex items-center overflow-hidden\">\n  <div class=\"absolute inset-0 z-0\">\n    <img class=\"w-full h-full object-cover\" alt=\"\" src=\"https://images.unsplash.com/photo-1591286574655-19eaf805d2ea?q=80&w=2000&auto=format&fit=crop\"/>\n    <div class=\"absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/50 to-primary/30\"></div>\n  </div>\n  <div class=\"relative z-10 max-w-container-max mx-auto px-gutter w-full\">\n    <div class=\"max-w-3xl\">\n      <span class=\"inline-block bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full font-label-bold mb-stack-md\">Locations</span>\n      <h1 class=\"font-h1 text-h1 text-white mb-stack-md drop-shadow-md\">Find your Montenegro</h1>\n      <p class=\"font-body-lg text-body-lg text-white/90 leading-relaxed\">A country smaller than Connecticut, packed with UNESCO old towns, glacier lakes, super-yacht marinas, and roads that genuinely belong on a postcard. Pick a base, pick up a car, and start driving.</p>\n    </div>\n  </div>\n</section>",
                "_title": "Find your Montenegro"
              }
            }
