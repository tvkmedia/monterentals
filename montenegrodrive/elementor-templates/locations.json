            {
              "id": "dfef201",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"py-section-padding px-gutter\">\n  <div class=\"max-w-container-max mx-auto\">\n    <div class=\"mb-stack-lg\">\n      <h2 class=\"font-h2 text-h2 text-primary mb-stack-sm\">Must-visit cities</h2>\n      <p class=\"text-secondary font-body-md max-w-2xl\">From the walled medieval towns of the coast to the modern capital inland, every city has its own character \u2014 and its own MontenegroDrive pick-up counter.</p>\n    </div>\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Budva\" src=\"https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/e3/f4/62/love-of-kamenovo.jpg?w=500&h=500&s=1\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Budva</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Walled medieval old town, sandy beaches, the liveliest nightlife on the Adriatic.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            142 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Kotor\" src=\"https://cdn.prod.website-files.com/67ed5312eb95096e863b1fde/6862e290b75ae548562d02ac_2.jpg\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Kotor</h3>\n          <p class=\"text-secondary text-body-md mb-4\">UNESCO World Heritage bay with a Venetian-era fortified town and cliff-side fortifications.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            98 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Podgorica\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/podgorica.webp\" onerror=\"this.onerror=null;this.src='https://www.vijesti.me/data/images/2024/02/19/12/5549456_shutterstock-1845962032_ls.jpg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Podgorica</h3>\n          <p class=\"text-secondary text-body-md mb-4\">The modern capital. Millennium Bridge, caf\u00e9 culture, and the gateway to the lakes.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            215 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Tivat\" src=\"https://bilder.apollo.se/tivat-1664477562-565078-ImageGalleryX2.jpg\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Tivat</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Porto Montenegro super-yacht marina and the country's busiest international airport.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            167 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Herceg Novi\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/herceg-novi.webp\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Herceg Novi</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Fortress city at the mouth of the Bay of Kotor \u2014 botanical gardens and old steps.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            76 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Cetinje\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/cetinje.webp\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Cetinje</h3>\n          <p class=\"text-secondary text-body-md mb-4\">The old royal capital. Monasteries, museums and the start of the Lov&#263;en climb.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            42 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Bar\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/bar.webp\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Bar</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Olive-tree groves, the Stari Bar ruins and the ferry link to Bari, Italy.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            58 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Ulcinj\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/ulcinj.webp\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">Ulcinj</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Long sandy beaches, an Ottoman-era citadel and Montenegro's Albanian-speaking south.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            64 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group bg-white rounded-xl shadow-ambient overflow-hidden border border-outline-variant/30 hover:shadow-lg transition-all\">\n        <div class=\"h-56 overflow-hidden bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"\u017dabljak\" src=\"https://www.hireandtravel.com/app-assets/images/Country/me/zabljak.webp\" onerror=\"this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'\"/>\n        </div>\n        <div class=\"p-6\">\n          <h3 class=\"font-h3 text-h3 text-primary mb-2\">&#381;abljak</h3>\n          <p class=\"text-secondary text-body-md mb-4\">Highest town in the Balkans \u2014 gateway to Durmitor National Park and the Tara Canyon.</p>\n          <p class=\"text-body-sm text-primary flex items-center gap-2 font-label-bold\">\n            <span class=\"material-symbols-outlined text-[18px]\">car_rental</span>\n            31 cars available\n          </p>\n        </div>\n      </a>\n    </div>\n  </div>\n</section>",
                "_title": "Must-visit cities"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
    },
