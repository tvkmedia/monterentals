          "elements": [
            {
              "id": "64d3226",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"py-section-padding px-gutter max-w-container-max mx-auto\">\n  <div class=\"flex flex-col md:flex-row justify-between items-end mb-stack-lg gap-4\">\n    <div class=\"max-w-2xl\">\n      <h2 class=\"font-h2 text-h2 text-primary mb-2\">Best 4x4 Routes</h2>\n      <p class=\"text-secondary font-body-md\">For those who seek the path less traveled. Discover the rugged beauty of the Montenegrin highlands where paved roads end and adventure begins.</p>\n    </div>\n  </div>\n  <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n    <div class=\"flex flex-col gap-4\">\n      <div class=\"aspect-[4/3] rounded-xl overflow-hidden shadow-ambient\">\n        <img alt=\"The Cursed Mountains\" class=\"w-full h-full object-cover\" src=\"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=1400&auto=format&fit=crop\"/>\n      </div>\n      <div>\n        <h4 class=\"font-h3 text-[20px] text-primary mb-2\">Prokletije: The Cursed Mountains</h4>\n        <p class=\"text-body-sm text-secondary mb-4\">Challenge yourself on the steep trails leading to the heart of the Balkans' most dramatic range.</p>\n        <a class=\"text-primary font-label-bold flex items-center gap-1 hover:gap-2 transition-all\" href=\"article-prokletije.html\">Route Details <span class=\"material-symbols-outlined text-[18px]\">arrow_right_alt</span></a>\n      </div>\n    </div>\n    <div class=\"flex flex-col gap-4\">\n      <div class=\"aspect-[4/3] rounded-xl overflow-hidden shadow-ambient\">\n        <img alt=\"Mountain pasture in the Sinjajevina Highlands\" class=\"w-full h-full object-cover\" src=\"https://commons.wikimedia.org/wiki/Special:FilePath/Sinjajevina.jpg?width=1400\" onerror=\"if(!this.dataset.f){this.dataset.f=1;this.src='https://commons.wikimedia.org/wiki/Special:FilePath/Sinjajevina_planina.jpg?width=1400'}else if(this.dataset.f==1){this.dataset.f=2;this.src='https://images.pexels.com/photos/417173/pexels-photo-417173.jpeg'}else{this.onerror=null;this.src='https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg'}\"/>\n      </div>\n      <div>\n        <h4 class=\"font-h3 text-[20px] text-primary mb-2\">The Sinjajevina Highlands</h4>\n        <p class=\"text-body-sm text-secondary mb-4\">Europe's second-largest mountain pasture offers endless rolling plateaus and ancient shepherd huts.</p>\n        <a class=\"text-primary font-label-bold flex items-center gap-1 hover:gap-2 transition-all\" href=\"article-sinjajevina.html\">Route Details <span class=\"material-symbols-outlined text-[18px]\">arrow_right_alt</span></a>\n      </div>\n    </div>\n    <div class=\"flex flex-col gap-4\">\n      <div class=\"aspect-[4/3] rounded-xl overflow-hidden shadow-ambient\">\n        <img alt=\"Komovi Peaks\" class=\"w-full h-full object-cover\" src=\"https://images.unsplash.com/photo-1454942901704-3c44c11b2ad1?q=80&w=1400&auto=format&fit=crop\"/>\n      </div>\n      <div>\n        <h4 class=\"font-h3 text-[20px] text-primary mb-2\">The Circular Komovi Route</h4>\n        <p class=\"text-body-sm text-secondary mb-4\">A perfect mix of forest trails and limestone rock crawls around three of Montenegro's most iconic peaks.</p>\n        <a class=\"text-primary font-label-bold flex items-center gap-1 hover:gap-2 transition-all\" href=\"article-komovi.html\">Route Details <span class=\"material-symbols-outlined text-[18px]\">arrow_right_alt</span></a>\n      </div>\n    </div>\n  </div>\n</section>",
                "_title": "Best 4x4 Routes"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
    },
