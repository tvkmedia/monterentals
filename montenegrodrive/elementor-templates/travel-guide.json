      },
      "elements": [
        {
          "id": "4760ead",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "_inline_size": null
          },
          "elements": [
            {
              "id": "c3359ae",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"py-section-padding bg-primary text-white\">\n  <div class=\"max-w-container-max mx-auto px-gutter\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\">\n      <div>\n        <h2 class=\"font-h2 text-h2 mb-stack-md\">Border Crossing Rules</h2>\n        <p class=\"font-body-lg text-white/80 mb-stack-lg\">\n          Planning to visit Croatia, Albania, or Bosnia? MontenegroDrive makes international travel easy. Here is everything you need to know about taking your rental car across the border.\n        </p>\n        <div class=\"space-y-6\">\n          <div class=\"flex gap-4\">\n            <div class=\"flex-shrink-0 w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center text-white\">\n              <span class=\"material-symbols-outlined\">description</span>\n            </div>\n            <div>\n              <h4 class=\"font-label-bold mb-1\">The Green Card</h4>\n              <p class=\"text-body-sm text-white/70\">Mandatory insurance for all neighboring countries. We provide this document with every cross-border rental.</p>\n            </div>\n          </div>\n          <div class=\"flex gap-4\">\n            <div class=\"flex-shrink-0 w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center text-white\">\n              <span class=\"material-symbols-outlined\">badge</span>\n            </div>\n            <div>\n              <h4 class=\"font-label-bold mb-1\">Required Documents</h4>\n              <p class=\"text-body-sm text-white/70\">Always keep your passport, driving license, and rental agreement ready at border checkpoints.</p>\n            </div>\n          </div>\n          <div class=\"flex gap-4\">\n            <div class=\"flex-shrink-0 w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center text-white\">\n              <span class=\"material-symbols-outlined\">map</span>\n            </div>\n            <div>\n              <h4 class=\"font-label-bold mb-1\">Permitted Countries</h4>\n              <p class=\"text-body-sm text-white/70\">Our vehicles are authorized for travel within the EU and Western Balkans with prior notification.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"bg-white/5 rounded-2xl p-8 border border-white/10\">\n        <h3 class=\"font-h3 text-h3 mb-6\">Border Wait Times</h3>\n        <p class=\"text-body-md text-white/80 mb-6\">Check live border traffic before you head out. Summer peak seasons can result in significant delays at popular crossings like Debeli Brijeg (Croatia).</p>\n        <div class=\"space-y-4\">\n          <div class=\"flex justify-between items-center pb-4 border-b border-white/10\">\n            <span>Croatia (Debeli Brijeg)</span>\n            <span class=\"px-3 py-1 bg-error/20 text-red-300 rounded-full text-[12px] font-label-bold uppercase\">60+ min</span>\n          </div>\n          <div class=\"flex justify-between items-center pb-4 border-b border-white/10\">\n            <span>Albania (Sukobin)</span>\n            <span class=\"px-3 py-1 bg-secondary-container/20 text-secondary-fixed rounded-full text-[12px] font-label-bold uppercase\">20 min</span>\n          </div>\n          <div class=\"flex justify-between items-center pb-4 border-b border-white/10\">\n            <span>Bosnia (Sitnica)</span>\n            <span class=\"px-3 py-1 bg-secondary-container/20 text-secondary-fixed rounded-full text-[12px] font-label-bold uppercase\">15 min</span>\n          </div>\n        </div>\n        <button class=\"w-full mt-8 py-3 rounded-lg border border-white/30 font-label-bold hover:bg-white hover:text-primary transition-all\">\n          Download Full Border Guide\n        </button>\n      </div>\n    </div>\n  </div>\n</section>",
                "_title": "Border Crossing Rules"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
    },
