              "id": "b8fa8e7",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"relative h-[680px] flex items-center overflow-hidden\">\n  <div class=\"absolute inset-0 z-0\">\n    <img class=\"w-full h-full object-cover\" alt=\"Mountain road in Montenegro\" src=\"https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg\" loading=\"eager\"/>\n    <div class=\"absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/40 to-transparent\"></div>\n  </div>\n  <div class=\"relative z-10 max-w-container-max mx-auto px-gutter w-full\">\n    <div class=\"max-w-2xl\">\n      <span class=\"inline-block bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full font-label-bold mb-stack-md\">Discover Montenegro</span>\n      <h1 class=\"font-h1 text-h1 text-white mb-stack-md\">The road to your next great adventure</h1>\n      <p class=\"font-body-lg text-body-lg text-white/90 mb-stack-lg leading-relaxed\">\n        From the breathtaking depths of the Tara Canyon to the majestic peaks of Durmitor. Explore Europe's best-kept secret with our exclusive guides and premium rental cars.\n      </p>\n      <div class=\"flex flex-wrap gap-stack-md\">\n        <a href=\"search.html\" class=\"bg-[#FF6B00] text-on-primary px-8 py-4 rounded-lg font-label-bold shadow-lg hover:brightness-110 transition-all flex items-center gap-2\">\n          Book your road trip <span class=\"material-symbols-outlined\">arrow_forward</span>\n        </a>\n        <button class=\"bg-glass border border-white/30 text-primary px-8 py-4 rounded-lg font-label-bold hover:bg-white transition-colors\">\n          View travel guides\n        </button>\n      </div>\n    </div>\n  </div>\n</section>",
                "_title": "The road to your next great adventure"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
