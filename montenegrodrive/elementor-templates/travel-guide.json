                "html": "<header class=\"fixed top-0 w-full z-50 bg-surface shadow-sm\">\n  <div class=\"max-w-container-max mx-auto flex justify-between items-center px-gutter py-4\">\n    <a href=\"index.html\" class=\"flex items-center gap-3 group\" aria-label=\"MontenegroDrive \u2014 Home\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" viewbox=\"0 0 40 40\" class=\"w-10 h-10 flex-shrink-0 transition-transform group-hover:scale-105\" aria-hidden=\"true\">\n          <rect width=\"40\" height=\"40\" rx=\"8\" fill=\"#001835\"/>\n          <text x=\"20\" y=\"29\" font-family=\"'Plus Jakarta Sans', system-ui, sans-serif\" font-size=\"26\" font-weight=\"800\" text-anchor=\"middle\" fill=\"#FF5722\">M</text>\n        </svg>\n        <span class=\"font-h2 text-h2 font-bold text-primary leading-none\">MontenegroDrive</span>\n      </a>\n    <nav class=\"hidden md:flex gap-stack-lg items-center\">\n      <a class=\"text-secondary font-body-md hover:text-primary-container transition-colors\" href=\"search.html\">Fleet</a>\n      <a class=\"text-primary font-label-bold border-b-2 border-primary hover:text-primary-container transition-colors\" href=\"travel-guide.html\">Travel Guide</a>\n      <a class=\"text-secondary font-body-md hover:text-primary-container transition-colors\" href=\"search.html\">Rentals</a>\n      <a class=\"text-secondary font-body-md hover:text-primary-container transition-colors\" href=\"locations.html\">Locations</a>\n    </nav>\n    <div class=\"flex items-center gap-stack-md\">\n      <a class=\"hidden lg:block text-primary font-label-bold hover:opacity-80 transition-opacity\" href=\"support.html\">Support</a>\n      <a class=\"bg-[#FF6B00] text-white px-6 py-2.5 rounded-lg font-label-bold shadow-ambient hover:scale-[1.02] transition-transform\" href=\"manage-booking.html\">Manage Booking</a>\n    </div>\n  </div>\n</header>",
