            {
              "id": "777be4d",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"bg-surface-container-low py-section-padding\">\n  <div class=\"max-w-container-max mx-auto px-gutter grid grid-cols-1 lg:grid-cols-2 items-center gap-16\">\n    <div>\n      <h2 class=\"font-h2 text-h2 text-primary mb-stack-md\">Ready to roll out?</h2>\n      <p class=\"font-body-lg text-body-lg text-secondary mb-stack-lg\">\n        Find the perfect car for your adventure. We offer everything from agile convertibles for coastal roads to robust 4WD vehicles for the mountains.\n      </p>\n      <div class=\"flex flex-col gap-4\">\n        <div class=\"flex items-center gap-4 p-4 bg-white rounded-lg shadow-sm border border-outline-variant\">\n          <span class=\"material-symbols-outlined text-primary bg-secondary-container p-2 rounded-lg\">location_on</span>\n          <div>\n            <p class=\"text-body-sm text-secondary\">Choose location</p>\n            <p class=\"font-label-bold\">Podgorica Airport (TGD)</p>\n          </div>\n        </div>\n        <a href=\"search.html\" class=\"bg-[#FF6B00] text-white w-full py-4 rounded-lg font-label-bold shadow-lg hover:translate-y-[-2px] transition-all text-center\">\n          Search Available Cars\n        </a>\n      </div>\n    </div>\n    <div class=\"relative\">\n      <div class=\"aspect-square rounded-full bg-primary-container/5 absolute -top-10 -right-10 w-64 h-64 blur-3xl\"></div>\n      <img class=\"relative z-10 rounded-2xl shadow-ambient w-full\" alt=\"Luxury silver SUV\" src=\"https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1600&auto=format&fit=crop\"/>\n      <div class=\"absolute -bottom-6 -left-6 bg-white p-6 rounded-xl shadow-ambient z-20 flex items-center gap-4\">\n        <div class=\"w-12 h-12 bg-secondary-container rounded-full flex items-center justify-center\">\n          <span class=\"material-symbols-outlined text-primary\">verified</span>\n        </div>\n        <div>\n          <p class=\"font-label-bold\">Price Guarantee</p>\n          <p class=\"text-body-sm text-secondary\">No hidden fees</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
                "_title": "Ready to roll out?"
              }
            }
          ],
