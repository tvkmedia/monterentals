              "id": "dbb5745",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"py-section-padding px-gutter max-w-container-max mx-auto\">\n  <div class=\"flex justify-between items-end mb-stack-lg flex-wrap gap-4\">\n    <div>\n      <h2 class=\"font-h2 text-h2 text-primary\">Featured Stories</h2>\n      <p class=\"text-secondary font-body-md\">Inspiration for your next journey through the Balkans</p>\n    </div>\n    <a class=\"text-primary font-label-bold flex items-center gap-1 hover:underline underline-offset-4\" href=\"travel-guide.html#all-articles\">\n      View all articles <span class=\"material-symbols-outlined\">trending_flat</span>\n    </a>\n  </div>\n  <div class=\"grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[580px]\">\n\n    <!-- Main Feature -->\n    <a href=\"article-road-trip-tips.html\" class=\"md:col-span-8 group relative overflow-hidden rounded-xl shadow-ambient bg-surface-container min-h-[320px] block\">\n      <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Tara Canyon road trip\" src=\"https://images.unsplash.com/photo-1502301103665-0b95cc738daf?q=80&w=1800&auto=format&fit=crop\"/>\n      <div class=\"absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent\"></div>\n      <div class=\"absolute bottom-0 left-0 p-stack-lg\">\n        <div class=\"flex gap-2 mb-3\">\n          <span class=\"bg-secondary-container text-on-secondary-container px-3 py-1 rounded-md text-body-sm font-label-bold uppercase tracking-wider\">Guide</span>\n        </div>\n        <h3 class=\"font-h2 text-h2 text-white mb-2\">10 Tips for Your Montenegro Road Trip</h3>\n        <p class=\"text-white/80 font-body-md max-w-lg mb-4\">Everything from hidden gas stations to the most beautiful viewpoints along the coast.</p>\n        <span class=\"inline-flex items-center text-white font-label-bold gap-2 group-hover:gap-4 transition-all\">\n          Read more <span class=\"material-symbols-outlined\">east</span>\n        </span>\n      </div>\n    </a>\n\n    <!-- Secondary Features Stack -->\n    <div class=\"md:col-span-4 flex flex-col gap-6\">\n      <a href=\"article-panoramic-routes.html\" class=\"flex-1 group relative overflow-hidden rounded-xl shadow-ambient min-h-[260px] block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Durmitor Ring \u2014 one of Montenegro's panoramic routes\" src=\"https://images.myguide-cdn.com/md/content/2/large/panoramic-routes-of-montenegro-durmitor-ring-710896.jpg\"/>\n        <div class=\"absolute inset-0 bg-primary/40 group-hover:bg-primary/20 transition-colors\"></div>\n        <div class=\"absolute bottom-0 p-stack-md\">\n          <h3 class=\"font-h3 text-h3 text-white\">Best Panoramic Routes in Europe</h3>\n          <span class=\"text-white/90 text-body-sm font-label-bold mt-2 inline-block\">Explore the routes \u2192</span>\n        </div>\n      </a>\n      <a href=\"article-driving-rules.html\" class=\"flex-1 group relative overflow-hidden rounded-xl shadow-ambient min-h-[260px] block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Car rental contract\" src=\"https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?q=80&w=1400&auto=format&fit=crop\"/>\n        <div class=\"absolute inset-0 bg-primary/40 group-hover:bg-primary/20 transition-colors\"></div>\n        <div class=\"absolute bottom-0 p-stack-md\">\n          <h3 class=\"font-h3 text-h3 text-white\">Driving in Montenegro: What You Need to Know</h3>\n          <span class=\"text-white/90 text-body-sm font-label-bold mt-2 inline-block\">Safety Guide \u2192</span>\n        </div>\n      </a>\n    </div>\n\n  </div>\n</section>",
                "_title": "Featured Stories"
