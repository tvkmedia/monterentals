            {
              "id": "acfbc2b",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<main class=\"pt-24 pb-section-padding max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-12 gap-8\">\n\n  <!-- Sidebar Filters -->\n  <aside class=\"md:col-span-3 space-y-stack-lg\">\n    <div class=\"bg-surface-container-lowest p-6 rounded-xl shadow-custom border border-outline-variant/30\">\n      <h3 class=\"font-h3 text-h3 mb-6 text-primary\">Filters</h3>\n\n      <div class=\"mb-8\">\n        <label class=\"block font-label-bold text-primary mb-4\">Price Range</label>\n        <input class=\"w-full accent-primary\" max=\"2000\" min=\"200\" step=\"50\" type=\"range\" value=\"1000\"/>\n        <div class=\"flex justify-between mt-2 text-body-sm text-secondary\">\n          <span>200 \u20ac</span>\n          <span>2000 \u20ac+</span>\n        </div>\n      </div>\n\n      <div class=\"mb-8\">\n        <label class=\"block font-label-bold text-primary mb-4\">Car category</label>\n        <div class=\"space-y-3\">\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Economy</span>\n          </label>\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input checked class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">SUV</span>\n          </label>\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Luxury</span>\n          </label>\n        </div>\n      </div>\n\n      <div class=\"mb-8\">\n        <label class=\"block font-label-bold text-primary mb-4\">Fuel type</label>\n        <div class=\"space-y-3\">\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Petrol</span>\n          </label>\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Diesel</span>\n          </label>\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Electric / Hybrid</span>\n          </label>\n        </div>\n      </div>\n\n      <div>\n        <label class=\"block font-label-bold text-primary mb-4\">Supplier</label>\n        <div class=\"space-y-3\">\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Local Stars</span>\n          </label>\n          <label class=\"flex items-center gap-3 cursor-pointer group\">\n            <input class=\"rounded border-outline w-5 h-5 filter-checkbox transition-all\" type=\"checkbox\"/>\n            <span class=\"text-body-md group-hover:text-primary\">Global Drive</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    <!-- Side Promotion Card -->\n    <div class=\"bg-primary-container p-6 rounded-xl relative overflow-hidden text-on-primary\">\n      <div class=\"relative z-10\">\n        <h4 class=\"font-h3 text-h3 mb-2 text-white\">Full Insurance</h4>\n        <p class=\"text-body-sm opacity-90 mb-4 text-white\">Travel without worries with our Zero Excess premium coverage.</p>\n        <button class=\"text-white font-label-bold underline decoration-2 underline-offset-4\">Learn More</button>\n      </div>\n      <div class=\"absolute -bottom-4 -right-4 opacity-10 text-white\">\n        <span class=\"material-symbols-outlined\" style=\"font-size: 7rem;\">verified_user</span>\n      </div>\n    </div>\n  </aside>\n\n  <!-- Main Results -->\n  <div class=\"md:col-span-9\">\n    <!-- Sort Bar -->\n    <div class=\"bg-surface-container-lowest p-4 rounded-xl shadow-custom mb-8 flex flex-col sm:flex-row justify-between items-center gap-4\">\n      <div class=\"flex items-center gap-2 w-full sm:w-auto overflow-x-auto no-scrollbar\">\n        <button class=\"px-6 py-2 rounded-full bg-primary text-on-primary font-label-bold whitespace-nowrap\">Recommended</button>\n        <button class=\"px-6 py-2 rounded-full text-secondary hover:bg-secondary-container transition-colors font-label-bold whitespace-nowrap\">Lowest Price</button>\n        <button class=\"px-6 py-2 rounded-full text-secondary hover:bg-secondary-container transition-colors font-label-bold whitespace-nowrap\">Highest Rated</button>\n      </div>\n      <div class=\"text-body-sm text-secondary px-2\">\n        Found 24 cars in <span class=\"font-bold text-primary\">Budva, Montenegro</span>\n      </div>\n    </div>\n\n    <!-- Results List -->\n    <div class=\"space-y-6\">\n\n      <!-- Result Card 1: Economy -->\n      <article class=\"bg-surface-container-lowest rounded-xl overflow-hidden shadow-custom border border-transparent hover:border-primary/20 transition-all group grid grid-cols-1 md:grid-cols-12\">\n        <div class=\"md:col-span-4 relative overflow-hidden h-48 md:h-auto bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Volkswagen Polo\" src=\"https://images.unsplash.com/photo-1606664515524-ed2f786a0bd6?q=80&w=1400&auto=format&fit=crop\"/>\n          <div class=\"absolute top-3 left-3 flex gap-2\">\n            <span class=\"bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider\">Best Value</span>\n          </div>\n        </div>\n        <div class=\"md:col-span-5 p-6 flex flex-col justify-between\">\n          <div>\n            <h2 class=\"font-h3 text-h3 text-primary mb-1\">Volkswagen Polo <span class=\"font-normal text-secondary text-body-md italic\">or similar</span></h2>\n            <p class=\"text-body-sm text-on-surface-variant mb-4 flex items-center gap-2\">\n              <span class=\"material-symbols-outlined !text-base\">directions_car</span> Economy Class\n            </p>\n            <div class=\"grid grid-cols-2 gap-y-3\">\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">ac_unit</span>\n                <span class=\"text-body-sm\">Air Conditioning</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">person</span>\n                <span class=\"text-body-sm\">5 seats</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">settings</span>\n                <span class=\"text-body-sm\">Manual</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">local_gas_station</span>\n                <span class=\"text-body-sm\">Full to Full</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"mt-6 flex items-center gap-3\">\n            <div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center p-2\">\n              <span class=\"material-symbols-outlined text-primary\">local_taxi</span>\n            </div>\n            <div>\n              <span class=\"text-body-sm font-bold block leading-tight\">Local Stars Rental</span>\n              <span class=\"text-[10px] text-on-tertiary-container uppercase font-bold\">Recommended supplier</span>\n              <div class=\"flex items-center gap-1 mt-1\">\n                <span class=\"material-symbols-outlined text-primary !text-sm\">verified</span>\n                <span class=\"text-[10px] text-primary font-bold uppercase\">Verified Provider</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:col-span-3 p-6 bg-surface-container-low/30 border-l border-outline-variant/30 flex flex-col justify-end\">\n          <div class=\"text-right mb-4\">\n            <span class=\"block text-body-sm text-secondary\">Total for 3 days: 135 \u20ac</span>\n            <span class=\"block text-error font-label-bold text-[12px] my-1 uppercase tracking-tight\">Only 2 left at this price!</span>\n            <div class=\"flex items-baseline justify-end gap-1\">\n              <span class=\"font-price-display text-price-display text-primary\">45 \u20ac</span>\n              <span class=\"text-body-sm text-secondary\">/ day</span>\n            </div>\n          </div>\n          <button class=\"w-full bg-[#FF7E1D] text-white font-label-bold py-3.5 rounded-lg shadow-lg hover:brightness-110 transition-all uppercase tracking-wide\">View Offer</button>\n          <p class=\"text-[10px] text-center text-secondary mt-3 uppercase tracking-tighter\">Free cancellation until 48h before</p>\n        </div>\n      </article>\n\n      <!-- Result Card 2: SUV -->\n      <article class=\"bg-surface-container-lowest rounded-xl overflow-hidden shadow-custom border border-transparent hover:border-primary/20 transition-all group grid grid-cols-1 md:grid-cols-12\">\n        <div class=\"md:col-span-4 relative overflow-hidden h-48 md:h-auto bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Dacia Duster 4x4\" src=\"https://images.unsplash.com/photo-1609710228159-0fa9bd7c0827?q=80&w=1400&auto=format&fit=crop\"/>\n          <div class=\"absolute top-3 left-3 flex gap-2\">\n            <span class=\"bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider\">Top Rated</span>\n          </div>\n        </div>\n        <div class=\"md:col-span-5 p-6 flex flex-col justify-between\">\n          <div>\n            <h2 class=\"font-h3 text-h3 text-primary mb-1\">Dacia Duster 4x4 <span class=\"font-normal text-secondary text-body-md italic\">or similar</span></h2>\n            <p class=\"text-body-sm text-on-surface-variant mb-4 flex items-center gap-2\">\n              <span class=\"material-symbols-outlined !text-base\">terrain</span> SUV / Crossover\n            </p>\n            <div class=\"grid grid-cols-2 gap-y-3\">\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">ac_unit</span>\n                <span class=\"text-body-sm\">Air Conditioning</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">group</span>\n                <span class=\"text-body-sm\">5 seats</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">luggage</span>\n                <span class=\"text-body-sm\">3 Large Bags</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">settings</span>\n                <span class=\"text-body-sm\">Automatic</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"mt-6 flex items-center gap-3\">\n            <div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center p-2\">\n              <span class=\"material-symbols-outlined text-primary\">stars</span>\n            </div>\n            <div>\n              <span class=\"text-body-sm font-bold block leading-tight\">Global Drive</span>\n              <span class=\"text-[10px] text-on-tertiary-container uppercase font-bold\">Premium global network</span>\n              <div class=\"flex items-center gap-1 mt-1\">\n                <span class=\"material-symbols-outlined text-primary !text-sm\">verified</span>\n                <span class=\"text-[10px] text-primary font-bold uppercase\">Verified Provider</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:col-span-3 p-6 bg-surface-container-low/30 border-l border-outline-variant/30 flex flex-col justify-end\">\n          <div class=\"text-right mb-4\">\n            <span class=\"block text-body-sm text-secondary\">Total for 3 days: 255 \u20ac</span>\n            <span class=\"block text-tertiary-container font-label-bold text-[12px] my-1 uppercase tracking-tight\">High demand: Booked 5 times in the last hour</span>\n            <div class=\"flex items-baseline justify-end gap-1\">\n              <span class=\"font-price-display text-price-display text-primary\">85 \u20ac</span>\n              <span class=\"text-body-sm text-secondary\">/ day</span>\n            </div>\n          </div>\n          <button class=\"w-full bg-[#FF7E1D] text-white font-label-bold py-3.5 rounded-lg shadow-lg hover:brightness-110 transition-all uppercase tracking-wide\">View Offer</button>\n          <p class=\"text-[10px] text-center text-secondary mt-3 uppercase tracking-tighter\">Unlimited Mileage Included</p>\n        </div>\n      </article>\n\n      <!-- Result Card 3: Luxury -->\n      <article class=\"bg-surface-container-lowest rounded-xl overflow-hidden shadow-custom border border-transparent hover:border-primary/20 transition-all group grid grid-cols-1 md:grid-cols-12\">\n        <div class=\"md:col-span-4 relative overflow-hidden h-48 md:h-auto bg-surface-container-low\">\n          <img class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"BMW 5 Series\" src=\"https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=1400&auto=format&fit=crop\"/>\n        </div>\n        <div class=\"md:col-span-5 p-6 flex flex-col justify-between\">\n          <div>\n            <h2 class=\"font-h3 text-h3 text-primary mb-1\">BMW 5 Series <span class=\"font-normal text-secondary text-body-md italic\">or similar</span></h2>\n            <p class=\"text-body-sm text-on-surface-variant mb-4 flex items-center gap-2\">\n              <span class=\"material-symbols-outlined !text-base\">diamond</span> Luxury Class\n            </p>\n            <div class=\"grid grid-cols-2 gap-y-3\">\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">ac_unit</span>\n                <span class=\"text-body-sm\">Dual-zone AC</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">person</span>\n                <span class=\"text-body-sm\">5 seats</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">settings</span>\n                <span class=\"text-body-sm\">Automatic</span>\n              </div>\n              <div class=\"flex items-center gap-2 text-secondary\">\n                <span class=\"material-symbols-outlined !text-[20px]\">gps_fixed</span>\n                <span class=\"text-body-sm\">Built-in GPS</span>\n              </div>\n            </div>\n          </div>\n          <div class=\"mt-6 flex items-center gap-3\">\n            <div class=\"w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center p-2\">\n              <span class=\"material-symbols-outlined text-primary\">airport_shuttle</span>\n            </div>\n            <div>\n              <span class=\"text-body-sm font-bold block leading-tight\">Luxury Fleet MNE</span>\n              <span class=\"text-[10px] text-on-tertiary-container uppercase font-bold\">Chauffeur service available</span>\n              <div class=\"flex items-center gap-1 mt-1\">\n                <span class=\"material-symbols-outlined text-primary !text-sm\">verified</span>\n                <span class=\"text-[10px] text-primary font-bold uppercase\">Verified Provider</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:col-span-3 p-6 bg-surface-container-low/30 border-l border-outline-variant/30 flex flex-col justify-end\">\n          <div class=\"text-right mb-4\">\n            <span class=\"block text-body-sm text-secondary\">Total for 3 days: 435 \u20ac</span>\n            <span class=\"block text-error font-label-bold text-[12px] my-1 uppercase tracking-tight\">Limited availability for your dates</span>\n            <div class=\"flex items-baseline justify-end gap-1\">\n              <span class=\"font-price-display text-price-display text-primary\">145 \u20ac</span>\n              <span class=\"text-body-sm text-secondary\">/ day</span>\n            </div>\n          </div>\n          <button class=\"w-full bg-[#FF7E1D] text-white font-label-bold py-3.5 rounded-lg shadow-lg hover:brightness-110 transition-all uppercase tracking-wide\">View Offer</button>\n          <p class=\"text-[10px] text-center text-secondary mt-3 uppercase tracking-tighter\">Premium insurance included</p>\n        </div>\n      </article>\n\n    </div>\n\n    <!-- Pagination -->\n    <div class=\"mt-12 flex justify-center gap-2\">\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant text-primary hover:bg-surface-container-high transition-colors\">\n        <span class=\"material-symbols-outlined\">chevron_left</span>\n      </button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg bg-primary text-on-primary font-bold\">1</button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant text-primary hover:bg-surface-container-high transition-colors\">2</button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant text-primary hover:bg-surface-container-high transition-colors\">3</button>\n      <button class=\"w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant text-primary hover:bg-surface-container-high transition-colors\">\n        <span class=\"material-symbols-outlined\">chevron_right</span>\n      </button>\n    </div>\n  </div>\n</main>",
                "_title": "Filters"
              }
