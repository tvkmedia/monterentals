      "elements": [
        {
          "id": "4e4f3f2",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "_inline_size": null
          },
          "elements": [
            {
              "id": "d9af1e6",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"relative h-[460px] flex items-center overflow-hidden\">\n  <div class=\"absolute inset-0 z-0\">\n    <img class=\"w-full h-full object-cover\" alt=\"\" src=\"https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=2000&auto=format&fit=crop\"/>\n    <div class=\"absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/50 to-primary/30\"></div>\n  </div>\n  <div class=\"relative z-10 max-w-container-max mx-auto px-gutter w-full\">\n    <div class=\"max-w-3xl\">\n      <span class=\"inline-block bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full font-label-bold mb-stack-md\">Monte Club \u00b7 Partner programme</span>\n      <h1 class=\"font-h1 text-h1 text-white mb-stack-md drop-shadow-md\">Earn money with your idle car</h1>\n      <p class=\"font-body-lg text-body-lg text-white/90 leading-relaxed\">Monte Club is MontenegroDrive's partner programme. Do you have a car that you don't use? List it with us, we handle the customers, insurance, cleaning and maintenance \u2014 you collect a monthly payout.</p>\n    </div>\n  </div>\n</section>",
                "_title": "Earn money with your idle car"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
    },
    {
      "id": "6678e83",
