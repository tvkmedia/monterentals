        "_title": "How it works"
      },
      "elements": [
        {
          "id": "be3883a",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "_inline_size": null
          },
          "elements": [
            {
              "id": "1431006",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"py-section-padding px-gutter\">\n  <div class=\"max-w-container-max mx-auto\">\n    <div class=\"text-center mb-stack-lg\">\n      <h2 class=\"font-h2 text-h2 text-primary mb-stack-sm\">How it works</h2>\n      <p class=\"text-secondary font-body-md max-w-xl mx-auto\">Three steps, two visits to our office, and your car starts paying for itself.</p>\n    </div>\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n      <div class=\"bg-white rounded-xl p-8 shadow-ambient border border-outline-variant/30 relative\">\n        <div class=\"absolute -top-5 -left-5 w-12 h-12 rounded-full bg-[#FF5722] text-white font-h3 text-h3 flex items-center justify-center shadow-lg\">1</div>\n        <h3 class=\"font-h3 text-h3 text-primary mb-3 mt-2\">Apply online</h3>\n        <p class=\"text-secondary text-body-md\">Fill out the short form below with your car's details. We'll get back within 48 hours with an estimated monthly earning range based on category, age and pick-up city.</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-8 shadow-ambient border border-outline-variant/30 relative\">\n        <div class=\"absolute -top-5 -left-5 w-12 h-12 rounded-full bg-[#FF5722] text-white font-h3 text-h3 flex items-center justify-center shadow-lg\">2</div>\n        <h3 class=\"font-h3 text-h3 text-primary mb-3 mt-2\">Bring the car in</h3>\n        <p class=\"text-secondary text-body-md\">Drop the car at our Podgorica or Tivat office. We do a full inspection, photograph it for the fleet, hand you the partner agreement, and add the vehicle to availability.</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-8 shadow-ambient border border-outline-variant/30 relative\">\n        <div class=\"absolute -top-5 -left-5 w-12 h-12 rounded-full bg-[#FF5722] text-white font-h3 text-h3 flex items-center justify-center shadow-lg\">3</div>\n        <h3 class=\"font-h3 text-h3 text-primary mb-3 mt-2\">Get paid monthly</h3>\n        <p class=\"text-secondary text-body-md\">We pay 65% of net rental income on the 5th of each month, straight to your bank account, with a detailed booking-by-booking statement. Cancel any month with 30 days' notice.</p>\n      </div>\n    </div>\n  </div>\n</section>",
                "_title": "How it works"
              }
            }
          ],
          "isInner": false
        }
      ],
      "isInner": false
    },
    {
      "id": "d2b17d5",
