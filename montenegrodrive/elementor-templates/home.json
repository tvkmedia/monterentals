              "settings": {
                "html": "<section class=\"py-section-padding px-gutter bg-white\">\n  <div class=\"max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-3 gap-8\">\n    <div class=\"flex flex-col items-center text-center gap-4 p-8 rounded-xl bg-background border border-outline-variant/30 hover:shadow-md transition-all\">\n      <div class=\"w-16 h-16 bg-secondary-container flex items-center justify-center rounded-full text-primary mb-2\">\n        <span class=\"material-symbols-outlined text-[32px]\">credit_card_off</span>\n      </div>\n      <h3 class=\"font-h3 text-h3 text-primary\">No Hidden Fees</h3>\n      <p class=\"text-on-surface-variant font-body-md\">The price you see is the price you pay. No surprises at the counter.</p>\n    </div>\n    <div class=\"flex flex-col items-center text-center gap-4 p-8 rounded-xl bg-background border border-outline-variant/30 hover:shadow-md transition-all\">\n      <div class=\"w-16 h-16 bg-secondary-container flex items-center justify-center rounded-full text-primary mb-2\">\n        <span class=\"material-symbols-outlined text-[32px]\">verified</span>\n      </div>\n      <h3 class=\"font-h3 text-h3 text-primary\">Best Price Guarantee</h3>\n      <p class=\"text-on-surface-variant font-body-md\">We match market-leading prices to provide you with the best value for your money.</p>\n    </div>\n    <div class=\"flex flex-col items-center text-center gap-4 p-8 rounded-xl bg-background border border-outline-variant/30 hover:shadow-md transition-all\">\n      <div class=\"w-16 h-16 bg-secondary-container flex items-center justify-center rounded-full text-primary mb-2\">\n        <span class=\"material-symbols-outlined text-[32px]\">event_busy</span>\n      </div>\n      <h3 class=\"font-h3 text-h3 text-primary\">Free Cancellation</h3>\n      <p class=\"text-on-surface-variant font-body-md\">Plans can change. Cancel for free up to 48 hours before your rental begins.</p>\n    </div>\n  </div>\n</section>",
