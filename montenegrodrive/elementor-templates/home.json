              "settings": {
                "html": "<section class=\"py-section-padding px-gutter bg-background\">\n  <div class=\"max-w-container-max mx-auto flex flex-col gap-10\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end gap-4\">\n      <div class=\"flex flex-col gap-2\">\n        <h2 class=\"font-h2 text-h2 text-primary\">Popular Destinations</h2>\n        <p class=\"text-secondary font-body-md\">Discover the gems of Montenegro starting from our most popular locations.</p>\n      </div>\n      <button class=\"text-primary font-label-bold flex items-center gap-2 hover:underline\">\n        View all locations\n        <span class=\"material-symbols-outlined\">arrow_forward</span>\n      </button>\n    </div>\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n      <a href=\"search.html\" class=\"group relative h-[400px] rounded-2xl overflow-hidden cursor-pointer shadow-lg block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Sveti Stefan island, Budva, Montenegro\" src=\"https://montenegroconsulate.si/storage/2017/09/Sveti-Stefan-Montenegro-Adriatic-HD-Wallpaper-1920x1080.jpg\" loading=\"lazy\"/>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent\"></div>\n        <div class=\"absolute bottom-6 left-6 text-white\">\n          <h4 class=\"font-h3 text-h3 mb-1\">Budva</h4>\n          <p class=\"text-sm opacity-80 flex items-center gap-1\">\n            <span class=\"material-symbols-outlined text-sm\">car_rental</span>\n            142 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group relative h-[400px] rounded-2xl overflow-hidden cursor-pointer shadow-lg block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Perast in the Bay of Kotor, Montenegro\" src=\"https://www.ontheluce.com/wp-content/uploads/2023/08/perast-bay-of-kotor-960x600.jpg\" loading=\"lazy\"/>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent\"></div>\n        <div class=\"absolute bottom-6 left-6 text-white\">\n          <h4 class=\"font-h3 text-h3 mb-1\">Kotor</h4>\n          <p class=\"text-sm opacity-80 flex items-center gap-1\">\n            <span class=\"material-symbols-outlined text-sm\">car_rental</span>\n            98 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group relative h-[400px] rounded-2xl overflow-hidden cursor-pointer shadow-lg block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Podgorica, capital of Montenegro\" src=\"https://www.vijesti.me/data/images/2024/02/19/12/5549456_shutterstock-1845962032_ls.jpg\" loading=\"lazy\"/>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent\"></div>\n        <div class=\"absolute bottom-6 left-6 text-white\">\n          <h4 class=\"font-h3 text-h3 mb-1\">Podgorica</h4>\n          <p class=\"text-sm opacity-80 flex items-center gap-1\">\n            <span class=\"material-symbols-outlined text-sm\">car_rental</span>\n            215 cars available\n          </p>\n        </div>\n      </a>\n      <a href=\"search.html\" class=\"group relative h-[400px] rounded-2xl overflow-hidden cursor-pointer shadow-lg block\">\n        <img class=\"absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Tivat and the Bay of Kotor, Montenegro\" src=\"https://bilder.apollo.se/tivat-1664477562-565078-ImageGalleryX2.jpg\" loading=\"lazy\"/>\n        <div class=\"absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent\"></div>\n        <div class=\"absolute bottom-6 left-6 text-white\">\n          <h4 class=\"font-h3 text-h3 mb-1\">Tivat</h4>\n          <p class=\"text-sm opacity-80 flex items-center gap-1\">\n            <span class=\"material-symbols-outlined text-sm\">car_rental</span>\n            167 cars available\n          </p>\n        </div>\n      </a>\n    </div>\n  </div>\n</section>",
