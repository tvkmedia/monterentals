                "html": "<footer class=\"w-full py-section-padding px-gutter flex flex-col items-center gap-stack-lg bg-primary text-on-primary\">\n  <div class=\"max-w-container-max w-full flex flex-col md:flex-row justify-between items-start gap-12 border-b border-on-primary/10 pb-12\">\n    <div class=\"flex flex-col gap-4 max-w-[300px]\">\n      <span class=\"font-h3 text-h3 font-bold text-on-primary\">MontenegroDrive</span>\n      <p class=\"text-body-sm opacity-80\">Premium car rental in Montenegro for business travelers and tourists. We guarantee safety, quality, and the best prices.</p>\n    </div>\n    <div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\">\n      <div class=\"flex flex-col gap-4\">\n        <h5 class=\"font-label-bold text-tertiary-fixed\">Destinations</h5>\n        <ul class=\"flex flex-col gap-2 opacity-80 text-body-sm\">\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"search.html\">Budva</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"search.html\">Kotor</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"search.html\">Podgorica</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"search.html\">Tivat</a></li>\n        </ul>\n      </div>\n      <div class=\"flex flex-col gap-4\">\n        <h5 class=\"font-label-bold text-tertiary-fixed\">Support</h5>\n        <ul class=\"flex flex-col gap-2 opacity-80 text-body-sm\">\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"support.html\">Contact Us</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"support.html#faq\">FAQ</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"manage-booking.html\">Manage Booking</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"monte-club.html\">Monte Club</a></li>\n        </ul>\n      </div>\n      <div class=\"flex flex-col gap-4\">\n        <h5 class=\"font-label-bold text-tertiary-fixed\">Legal</h5>\n        <ul class=\"flex flex-col gap-2 opacity-80 text-body-sm\">\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"legal.html#privacy\">Privacy Policy</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"legal.html#terms\">Terms of Service</a></li>\n          <li><a class=\"hover:text-secondary-fixed transition-opacity\" href=\"legal.html#cookies\">Cookie Policy</a></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n  <div class=\"flex flex-col md:flex-row justify-between w-full max-w-container-max pt-2 opacity-70 text-body-sm\">\n    <p>\u00a9 2024 MontenegroDrive Car Rentals. All rights reserved.</p>\n    <div class=\"flex gap-6 mt-4 md:mt-0\">\n      <span class=\"material-symbols-outlined cursor-pointer hover:text-secondary-fixed\">public</span>\n      <span class=\"material-symbols-outlined cursor-pointer hover:text-secondary-fixed\">photo_camera</span>\n      <span class=\"material-symbols-outlined cursor-pointer hover:text-secondary-fixed\">share</span>\n    </div>\n  </div>\n</footer>",
