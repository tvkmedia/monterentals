            {
              "id": "417357c",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section id=\"hero\" class=\"hero-poster-bg relative min-h-[700px] flex items-center justify-center px-gutter py-section-padding overflow-hidden bg-primary\" style=\"background-image: linear-gradient(rgba(0,24,53,0.40), rgba(0,24,53,0.55)), url('https://r4.wallpaperflare.com/wallpaper/45/350/447/5bd33a3b9c50b-wallpaper-c080b5796fd62e43a8efe776cb1604d8.jpg'); background-size: cover; background-position: center;\">\n  <div class=\"max-w-container-max w-full flex flex-col items-center text-center gap-stack-lg z-10 relative\">\n    <div class=\"flex items-center gap-2 bg-white/20 backdrop-blur-md px-4 py-2 rounded-full border border-white/30 mb-2\">\n      <span class=\"material-symbols-outlined text-yellow-400\" style=\"font-variation-settings: 'FILL' 1;\">star</span>\n      <span class=\"text-white font-label-bold\">4.8/5 based on 2,500+ reviews</span>\n    </div>\n    <h1 class=\"font-h1 text-h1 text-white drop-shadow-md max-w-[800px]\">Find the Best Car Rental in Montenegro</h1>\n    <p class=\"text-white text-body-lg font-body-lg max-w-[600px] opacity-90\">Explore breathtaking views and picturesque towns with the market's safest and most affordable car rentals.</p>\n\n    <!-- Search Widget -->\n    <form action=\"search.html\" class=\"w-full max-w-[1100px] bg-white p-6 md:p-10 rounded-xl shadow-2xl flex flex-col gap-6 mt-8\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n        <div class=\"flex flex-col text-left gap-2\">\n          <label class=\"font-label-bold text-on-surface-variant text-sm flex items-center gap-2\">\n            <span class=\"material-symbols-outlined text-primary text-[20px]\">location_on</span>\n            Pick-up location\n          </label>\n          <input class=\"w-full h-[56px] border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container rounded-lg text-body-md bg-surface-container-lowest\" placeholder=\"Tivat Airport (TIV)\" type=\"text\"/>\n        </div>\n        <div class=\"flex flex-col text-left gap-2\">\n          <label class=\"font-label-bold text-on-surface-variant text-sm flex items-center gap-2\">\n            <span class=\"material-symbols-outlined text-primary text-[20px]\">flag</span>\n            Drop-off location\n          </label>\n          <input class=\"w-full h-[56px] border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container rounded-lg text-body-md bg-surface-container-lowest\" placeholder=\"Same as pick-up\" type=\"text\"/>\n        </div>\n        <div class=\"flex flex-col text-left gap-2\">\n          <label class=\"font-label-bold text-on-surface-variant text-sm flex items-center gap-2\">\n            <span class=\"material-symbols-outlined text-primary text-[20px]\">calendar_today</span>\n            Pick-up date\n          </label>\n          <input class=\"w-full h-[56px] border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container rounded-lg text-body-md bg-surface-container-lowest px-4\" type=\"date\"/>\n        </div>\n        <div class=\"flex flex-col text-left gap-2\">\n          <label class=\"font-label-bold text-on-surface-variant text-sm flex items-center gap-2\">\n            <span class=\"material-symbols-outlined text-primary text-[20px]\">event_repeat</span>\n            Return date\n          </label>\n          <input class=\"w-full h-[56px] border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container rounded-lg text-body-md bg-surface-container-lowest px-4\" type=\"date\"/>\n        </div>\n      </div>\n      <button type=\"submit\" class=\"bg-[#FF5722] text-white h-[60px] rounded-lg font-h3 text-h3 flex items-center justify-center gap-2 hover:bg-[#E64A19] transition-all shadow-lg hover:shadow-xl\">\n        Search Car Rental\n        <span class=\"material-symbols-outlined\">search</span>\n      </button>\n    </form>\n  </div>\n</section>",
                "_title": "Find the Best Car Rental in Montenegro"
