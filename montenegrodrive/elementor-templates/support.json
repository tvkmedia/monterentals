              "id": "7f3c7a2",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class=\"relative h-[460px] flex items-center overflow-hidden\">\n  <div class=\"absolute inset-0 z-0\">\n    <img class=\"w-full h-full object-cover\" alt=\"Montenegro coastline\" src=\"https://images.pexels.com/photos/16907812/pexels-photo-16907812.jpeg\"/>\n    <div class=\"absolute inset-0 bg-gradient-to-r from-primary/80 via-primary/50 to-primary/30\"></div>\n  </div>\n  <div class=\"relative z-10 max-w-container-max mx-auto px-gutter w-full\">\n    <div class=\"max-w-3xl\">\n      <span class=\"inline-block bg-secondary-container text-on-secondary-container px-4 py-1.5 rounded-full font-label-bold mb-stack-md\">Support &amp; Contact</span>\n      <h1 class=\"font-h1 text-h1 text-white mb-stack-md drop-shadow-md\">We're here to help</h1>\n      <p class=\"font-body-lg text-body-lg text-white/90 leading-relaxed\">Talk to our 24/7 multilingual support team about a booking, billing question, or anything in between. Average response time: under 2 hours.</p>\n    </div>\n  </div>\n</section>",
