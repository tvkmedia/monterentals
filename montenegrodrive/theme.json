{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary",       "name": "Adriatic Blue",   "color": "#001835" },
        { "slug": "primary-container", "name": "Primary Container", "color": "#0f2d52" },
        { "slug": "secondary",     "name": "Sky Blue",        "color": "#d3e2ed" },
        { "slug": "brand-accent",  "name": "Vibrant Orange",  "color": "#FF5722" },
        { "slug": "background",    "name": "Soft Background", "color": "#f7f9fb" },
        { "slug": "on-surface",    "name": "Ink",             "color": "#191c1e" },
        { "slug": "white",         "name": "White",           "color": "#ffffff" }
      ],
      "custom": true,
      "customGradient": true
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Plus Jakarta Sans', system-ui, sans-serif",
          "name": "Plus Jakarta Sans",
          "slug": "heading"
        },
        {
          "fontFamily": "'Inter', system-ui, sans-serif",
          "name": "Inter",
          "slug": "body"
        }
      ],
      "fontSizes": [
        { "slug": "body-sm",  "name": "Small",  "size": "14px" },
        { "slug": "body-md",  "name": "Medium", "size": "16px" },
        { "slug": "body-lg",  "name": "Large",  "size": "18px" },
        { "slug": "h3",       "name": "H3",     "size": "24px" },
        { "slug": "h2",       "name": "H2",     "size": "32px" },
        { "slug": "h1",       "name": "H1",     "size": "48px" }
      ]
    },
    "layout": {
      "contentSize": "1280px",
      "wideSize": "1280px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px", "rem", "em", "%", "vh", "vw"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--on-surface)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--body-md)",
      "lineHeight": "1.5"
    },
    "elements": {
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--h1)", "fontWeight": "700", "lineHeight": "1.2" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--h2)", "fontWeight": "700", "lineHeight": "1.3" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "fontSize": "var(--wp--preset--font-size--h3)", "fontWeight": "600", "lineHeight": "1.4" } },
      "link": { "color": { "text": "var(--wp--preset--color--primary)" } }
    }
  }
}
